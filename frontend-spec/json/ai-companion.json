{
  "companion_features": {
    "profile": {
      "api": "GET /api/companion/profile",
      "update_api": "PATCH /api/companion/profile",
      "fields": ["learningStyle", "currentGoal", "preferredStudyTime", "weakSubjects", "strongSubjects", "totalSessions", "currentStreakDays", "longestStreakDays", "engagementScore"]
    },
    "dashboard": {
      "api": "GET /api/companion/dashboard",
      "contains": ["profile", "recentInsights", "dueFlashcards", "weeklyProgress", "todayRecommendations"],
      "cache_time": "5min"
    },
    "sessions": {
      "start_api": "POST /api/companion/sessions/start",
      "complete_api": "POST /api/companion/sessions/{id}/complete",
      "history_api": "GET /api/companion/sessions",
      "types": ["Quiz", "Flashcards", "ConceptReview", "ExamPrep", "WeaknessReview", "FreeStudy"],
      "sm2_quality_scale": "0=blackout, 1=wrong, 2=wrong+hint, 3=correct+hard, 4=correct, 5=perfect"
    },
    "flashcards": {
      "generate_api": "POST /api/companion/flashcards/generate",
      "decks_api": "GET /api/companion/flashcards",
      "deck_api": "GET /api/companion/flashcards/{deckId}",
      "review_api": "POST /api/companion/flashcards/cards/{cardId}/review",
      "due_api": "GET /api/companion/flashcards/due",
      "algorithm": "SM-2 spaced repetition",
      "difficulties": ["Easy", "Medium", "Hard", "mixed"]
    },
    "insights": {
      "api": "GET /api/companion/insights",
      "acknowledge_api": "POST /api/companion/insights/{id}/acknowledge",
      "types": [
        "InactivityAlert", "ExamApproaching", "AssignmentDeadline",
        "StreakMilestone", "GoalAchieved", "StudyPlanRecommendation",
        "RiskAlert", "WeeklyReport", "MonthlyReport",
        "ImprovementDetected", "WeaknessDetected",
        "TeachingRecommendation", "ClassPerformanceAlert"
      ],
      "priorities": ["Low", "Medium", "High", "Urgent"]
    },
    "background_jobs": {
      "service": "AiFollowUpBackgroundService",
      "interval": "every 6 hours",
      "triggers": [
        "student inactive 7+ days",
        "exam in next 7 days",
        "assignment due in 48 hours",
        "grade < 50",
        "streak milestone (7, 14, 30 days)",
        "weekly report on Mondays"
      ]
    }
  },
  "chat_intents": [
    "general_chat", "academic_coach", "backend_api_query",
    "generate_exam", "result_query", "study_plan", "regulation",
    "quiz_me", "generate_flashcards", "academic_advice",
    "complaint_submit", "material_explanation", "assignment_query",
    "action_execute", "progress_report", "learning_assistant",
    "doctor_analytics", "doctor_risk_students", "doctor_weak_topics"
  ]
}
