{
  "teaching_intelligence": {
    "base_path": "/api/teaching-intelligence",
    "roles": ["Doctor", "SuperAdmin"],
    "refresh_interval": "hourly (background service)",
    "snapshot_table": "StudentIntelligenceSnapshot",
    "endpoints": [
      { "method": "GET", "path": "/dashboard", "returns": "TeachingDashboardDto", "cache": "10min" },
      { "method": "GET", "path": "/offerings", "returns": "DoctorOfferingSummaryDto[]", "cache": "10min" },
      { "method": "GET", "path": "/offerings/{id}/analytics", "returns": "ClassIntelligenceDto", "cache": "10min" },
      { "method": "GET", "path": "/offerings/{id}/students", "returns": "StudentIntelligenceDto[]", "filters": ["riskLevel", "atRiskOnly", "trend", "page", "pageSize", "sortBy", "sortDir"] },
      { "method": "GET", "path": "/offerings/{id}/students/{sid}", "returns": "StudentIntelligenceDto" },
      { "method": "GET", "path": "/students/at-risk", "returns": "StudentIntelligenceDto[]", "query": "minRiskLevel=medium" },
      { "method": "GET", "path": "/offerings/{id}/students/most-improved", "returns": "StudentIntelligenceDto[]", "query": "limit=10" },
      { "method": "GET", "path": "/offerings/{id}/topics", "returns": "TopicAnalyticsDto" },
      { "method": "GET", "path": "/alerts", "returns": "TeachingAlertDto[]" },
      { "method": "POST", "path": "/alerts/{id}/read", "returns": "204" },
      { "method": "GET", "path": "/insights", "returns": "TeachingInsightDto[]" },
      { "method": "GET", "path": "/offerings/{id}/export", "returns": "ExcelExportMetaDto (29 columns)" },
      { "method": "GET", "path": "/batches/{id}/export", "returns": "ExcelExportMetaDto" },
      { "method": "POST", "path": "/offerings/{id}/refresh", "returns": "202 Accepted" },
      { "method": "POST", "path": "/refresh-all", "returns": "202 Accepted" }
    ],
    "risk_scoring": {
      "algorithm": "GradeRisk(0-35) + AttendanceRisk(0-30) + AssignmentRisk(0-20) + EngagementRisk(0-15)",
      "levels": {
        "Low": "0-29",
        "Medium": "30-54",
        "High": "55-74",
        "Critical": "75-100"
      }
    },
    "excel_columns": [
      "UniversityId", "StudentName", "BatchName", "GroupName", "DepartmentName", "CollegeName", "SubjectName",
      "FinalScore", "MidtermScore", "CourseworkScore", "FinalExamScore", "GradeCategory",
      "TotalSessions", "AttendedSessions", "AttendancePercent",
      "TotalAssignments", "SubmittedAssignments", "MissingAssignments", "AssignmentCompletionRate",
      "TotalExams", "AvgExamScore", "AvgQuizScore",
      "RiskScore", "RiskLevel", "RiskFactors",
      "AiSessions", "StudyMinutes", "StreakDays"
    ],
    "offering_health": {
      "excellent": "avg >= 70 && att >= 80 && atRiskPct < 10%",
      "good": "avg >= 60 && att >= 70 && atRiskPct < 25%",
      "concerning": "avg >= 50 && att >= 60 && atRiskPct < 40%",
      "critical": "otherwise"
    }
  }
}
