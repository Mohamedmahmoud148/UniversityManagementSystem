{
  "dashboards": {
    "student": {
      "route": "/student/dashboard",
      "apis": [
        { "key": "studentDashboard", "endpoint": "GET /api/analytics/dashboard/student", "staleTime": "10min" },
        { "key": "gpa", "endpoint": "GET /api/gpa/my-gpa", "staleTime": "10min" },
        { "key": "upcomingExams", "endpoint": "GET /api/exams/my-enrolled-exams", "staleTime": "5min" },
        { "key": "companion", "endpoint": "GET /api/companion/dashboard", "staleTime": "5min" },
        { "key": "notifications", "endpoint": "GET /api/notification", "staleTime": "1min", "refetchInterval": "60s" }
      ],
      "widgets_order": [
        "GPACard (1/3)", "AttendanceCard (1/3)", "CompanionQuickAccess (1/3)",
        "UpcomingExams (1/2)", "DueAssignments (1/2)",
        "CourseGrid (full)",
        "AIInsightsFeed (1/2)", "TodayStudyPlan (1/2)"
      ]
    },
    "doctor": {
      "route": "/doctor/dashboard",
      "apis": [
        { "key": "teachingDashboard", "endpoint": "GET /api/teaching-intelligence/dashboard", "staleTime": "10min" },
        { "key": "alerts", "endpoint": "GET /api/teaching-intelligence/alerts?unreadOnly=true", "staleTime": "5min" }
      ],
      "widgets_order": [
        "StatsRow (full): totalStudents, criticalRisk, highRisk, avgGrade, avgAttendance",
        "AIRecommendations (1/3)", "OfferingHealthCards (2/3)",
        "AtRiskStudentsTable (full)",
        "WeakTopicsList (1/2)", "ClassComparisonChart (1/2)",
        "TeachingAlertsFeed (full)"
      ]
    },
    "admin": {
      "route": "/admin/dashboard",
      "apis": [
        { "key": "adminDashboard", "endpoint": "GET /api/analytics/dashboard/admin", "staleTime": "5min" },
        { "key": "summary", "endpoint": "GET /api/analytics/summary", "staleTime": "5min" },
        { "key": "atRisk", "endpoint": "GET /api/risk/at-risk-students", "staleTime": "10min" }
      ],
      "widgets_order": [
        "SystemStats (full row): 5 cards",
        "EnrollmentTrendChart (2/3)", "DepartmentPieChart (1/3)",
        "AtRiskStudentsList (1/2)", "RecentActivityFeed (1/2)"
      ]
    }
  }
}
