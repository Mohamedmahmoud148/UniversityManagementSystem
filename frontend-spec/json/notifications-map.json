{
  "notification_system": {
    "delivery_methods": ["REST polling", "SignalR real-time push"],
    "polling_interval": "60 seconds",
    "signalr_hub": "/hubs/notifications",
    "signalr_event": "ReceiveNotification",
    "api": {
      "get_all": "GET /api/notification",
      "mark_read": "PUT /api/notification/{id}/read",
      "admin_broadcast": "POST /api/notification",
      "doctor_send": "POST /api/notification/send-to-my-students",
      "delete": "DELETE /api/notification/{id}"
    },
    "notification_types": [
      { "source": "AiFollowUpBackgroundService", "type": "InactivityAlert", "icon": "😴", "color": "amber", "roles": ["Student"] },
      { "source": "AiFollowUpBackgroundService", "type": "ExamApproaching", "icon": "⚡", "color": "red", "roles": ["Student"] },
      { "source": "AiFollowUpBackgroundService", "type": "AssignmentDeadline", "icon": "📌", "color": "orange", "roles": ["Student"] },
      { "source": "AiFollowUpBackgroundService", "type": "StreakMilestone", "icon": "🔥", "color": "gold", "roles": ["Student"] },
      { "source": "AiFollowUpBackgroundService", "type": "WeeklyReport", "icon": "📊", "color": "blue", "roles": ["Student"] },
      { "source": "AiFollowUpBackgroundService", "type": "RiskAlert", "icon": "🚨", "color": "red", "roles": ["Student"] },
      { "source": "TeachingIntelligenceBackgroundService", "type": "ClassPerformanceAlert", "icon": "📈", "color": "orange", "roles": ["Doctor"] },
      { "source": "Manual (Admin/Doctor)", "type": "General", "icon": "🔔", "color": "default", "roles": ["Student", "Doctor", "Admin"] }
    ],
    "store": {
      "name": "notificationStore",
      "state": ["notifications[]", "unreadCount"],
      "actions": ["setNotifications", "addNotification", "markRead", "markAllRead"]
    }
  }
}
