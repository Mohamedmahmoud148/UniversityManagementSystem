{
  "chat_platform": {
    "route": "/chat",
    "roles": "all authenticated",
    "apis": {
      "get_conversations": "GET /api/Chat/conversations",
      "create_conversation": "POST /api/Chat/conversations",
      "get_messages": "GET /api/Chat/conversations/{id}/messages?page=1&size=50",
      "send_message": "POST /api/Chat/messages",
      "delete_conversation": "DELETE /api/Chat/conversations/{id}",
      "update_title": "PUT /api/Chat/conversations/{id}",
      "delete_message": "DELETE /api/Chat/messages/{id}"
    },
    "message_payload": {
      "conversationId": "string",
      "message": "string",
      "userId": "from auth store",
      "role": "from auth store",
      "history": "last 10 messages from state",
      "academicContext": "from auth store (studentId, batchId, etc.)"
    },
    "ai_response_fields": {
      "response": "string (markdown)",
      "intent_executed": "string",
      "model_used": "string",
      "suggestions": "string[]",
      "metadata": "optional structured data"
    },
    "supported_intents": [
      "general_chat", "academic_coach", "backend_api_query", "generate_exam",
      "result_query", "study_plan", "regulation", "quiz_me", "generate_flashcards",
      "academic_advice", "complaint_submit", "material_explanation",
      "assignment_query", "action_execute", "progress_report", "learning_assistant",
      "doctor_analytics", "doctor_risk_students", "doctor_weak_topics"
    ],
    "ui_requirements": {
      "ai_response": "render as markdown using react-markdown",
      "typing_indicator": "animated dots while waiting",
      "suggestions": "clickable chips below AI message",
      "history_loading": "infinite scroll upward",
      "auto_scroll": "scroll to bottom on new message",
      "message_persistence": "saved to DB via .NET backend"
    },
    "keyboard_shortcuts": {
      "send": "Enter",
      "new_line": "Shift+Enter",
      "new_conversation": "Ctrl+N"
    }
  }
}
